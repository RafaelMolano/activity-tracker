# ============================================================
# Copia este archivo como .env y ajusta los valores
# cp .env.example .env
# ============================================================

# --- Base de datos MySQL ---
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_USER=activity_user
MYSQL_PASSWORD=cambia_esta_contrasena
MYSQL_DB=activity_tracker
DATABASE_URL=mysql+aiomysql://${MYSQL_USER}:${MYSQL_PASSWORD}@${MYSQL_HOST}:${MYSQL_PORT}/${MYSQL_DB}

# --- JWT ---
# Genera una clave segura con: openssl rand -hex 32
SECRET_KEY=cambia_esto_por_una_clave_secreta_de_al_menos_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- App ---
APP_ENV=development
# En producción cambiar a False
DEBUG=True
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# --- Seed (usuario admin inicial) ---
FIRST_ADMIN_EMAIL=admin@empresa.com
FIRST_ADMIN_PASSWORD=Admin123456
FIRST_ADMIN_NAME=Administrador
